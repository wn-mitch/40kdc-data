{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://40kdc.dev/schemas/enrichment/phase-mapping.schema.json",
  "title": "Phase Mapping",
  "type": "object",
  "properties": {
    "source_id": { "$ref": "../defs/common.schema.json#/$defs/entity-id" },
    "source_type": { "$ref": "../defs/common.schema.json#/$defs/source-type" },
    "phases": { "$ref": "../defs/common.schema.json#/$defs/phase-list" },
    "game_version": { "$ref": "../defs/game-version-ref.schema.json" },
